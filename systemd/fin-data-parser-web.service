[Unit]
Description=Korean Stock Sector Screener web interface (Streamlit)
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/fin_data_parser
ExecStart=/home/ubuntu/fin_data_parser/.venv/bin/streamlit run app/Home.py --server.headless true --server.port 8501 --server.address 0.0.0.0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
